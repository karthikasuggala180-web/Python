while True:

    print("MINI ARCADE")
    print("1. Guessing Game")
    print("2. Rock Paper Scissors")
    print("3. Exit")

    try:
        choice = input("Enter your choice: ")

        if choice not in ["1","2","3"]:
            raise ValueError

    except ValueError:
        print("Invalid choice! Please enter 1, 2, or 3.")
        continue

    if choice == "3":
        print("Thank you for playing")
        break
